# Copy this file to `.streamlit/secrets.toml` and fill in real values.
# The real secrets.toml is gitignored — never commit it.

# Neon Postgres pooled connection string.
# Get it from the Neon console (use the *pooled* connection string).
# If left unset, the app falls back to a local SQLite file (app.db) for dev/offline.
DATABASE_URL = "postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign auth session cookies. Use a long random string.
COOKIE_SECRET = "change-me-to-a-long-random-string"
